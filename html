<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>BeatKey — BPM & Key Detector</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;700;800&display=swap" rel="stylesheet">
</head>
<body>

  <!-- ═══ AUTH OVERLAY ═══════════════════════════════════════ -->
  <div class="auth-overlay" id="authOverlay">
    <div class="auth-card" id="authCard">

      <!-- Logo dans la modale -->
      <div class="auth-logo">Beat<span>Key</span></div>
      <p class="auth-sub" id="authSub">Connecte-toi pour accéder à BeatKey</p>

      <!-- Tabs -->
      <div class="auth-tabs">
        <button class="auth-tab active" id="tabLogin" data-tab="login">Connexion</button>
        <button class="auth-tab" id="tabRegister" data-tab="register">S'enregistrer</button>
      </div>

      <!-- OAuth -->
      <div class="auth-oauth">
        <button class="oauth-btn" id="oauthGoogle">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          <span>Continuer avec Google</span>
        </button>
        <button class="oauth-btn" id="oauthApple">
          <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
          <span>Continuer avec Apple</span>
        </button>
      </div>

      <!-- Séparateur -->
      <div class="auth-sep"><span>ou</span></div>

      <!-- Formulaire login -->
      <div class="auth-form" id="formLogin">
        <div class="auth-field">
          <label>Adresse e-mail</label>
          <input type="email" id="loginEmail" placeholder="toi@exemple.com" autocomplete="email"/>
        </div>
        <div class="auth-field">
          <label>Mot de passe</label>
          <input type="password" id="loginPassword" placeholder="••••••••" autocomplete="current-password"/>
        </div>
        <p class="auth-forgot" id="forgotLink">Mot de passe oublié ?</p>
        <button class="auth-submit" id="btnLogin">Se connecter</button>
        <p class="auth-error" id="loginError"></p>
      </div>

      <!-- Formulaire register -->
      <div class="auth-form" id="formRegister" style="display:none">
        <div class="auth-field">
          <label>Nom d'utilisateur</label>
          <input type="text" id="regName" placeholder="DJ Shadow" autocomplete="username"/>
        </div>
        <div class="auth-field">
          <label>Adresse e-mail</label>
          <input type="email" id="regEmail" placeholder="toi@exemple.com" autocomplete="email"/>
        </div>
        <div class="auth-field">
          <label>Mot de passe</label>
          <input type="password" id="regPassword" placeholder="Min. 6 caractères" autocomplete="new-password"/>
        </div>
        <div class="auth-field">
          <label>Confirmer le mot de passe</label>
          <input type="password" id="regPassword2" placeholder="••••••••" autocomplete="new-password"/>
        </div>
        <button class="auth-submit" id="btnRegister">Créer mon compte</button>
        <p class="auth-error" id="registerError"></p>
      </div>

      <!-- Notice Firebase -->
      <p class="auth-notice">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
        Google &amp; Apple disponibles après hébergement (Firebase)
      </p>

    </div>
  </div>

  <!-- ═══ APP ════════════════════════════════════════════════ -->
  <div class="app-wrap" id="appWrap" style="display:none; width:100%; display:none; flex-direction:column; align-items:center;">

    <!-- HEADER -->
    <header class="header">
      <div class="header-top">
        <div class="logo">Beat<span>Key</span></div>
        <div class="header-right">
          <!-- Langue -->
          <div class="lang-switcher" id="langSwitcher">
            <button class="lang-btn active" data-lang="fr">FR</button>
            <button class="lang-btn" data-lang="en">EN</button>
            <button class="lang-btn" data-lang="es">ES</button>
            <button class="lang-btn" data-lang="it">IT</button>
            <button class="lang-btn" data-lang="de">DE</button>
          </div>
          <!-- Profil -->
          <div class="user-menu" id="userMenu">
            <button class="user-avatar-btn" id="userAvatarBtn">
              <span class="user-avatar" id="userAvatar">?</span>
            </button>
            <div class="user-dropdown" id="userDropdown">
              <div class="user-dropdown-info">
                <p class="user-dropdown-name" id="userDropdownName">—</p>
                <p class="user-dropdown-email" id="userDropdownEmail">—</p>
              </div>
              <hr class="dropdown-sep"/>
              <button class="dropdown-item dropdown-logout" id="btnLogout">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                Se déconnecter
              </button>
            </div>
          </div>
        </div>
      </div>
      <p class="tagline" data-i18n="tagline">BPM · Tonalité · Identification · Analyse musicale</p>
    </header>

    <main class="main">

      <!-- CLÉ API AUDD -->
      <section class="api-section" id="apiSection">
        <div class="api-saved" id="apiSaved">
          <div class="api-saved-left">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
            <span class="api-saved-dot"></span>
            <span class="api-saved-text" data-i18n="apiConnected">AudD connecté</span>
          </div>
          <div class="api-saved-right">
            <button id="btnEditKey" class="btn-text-action" data-i18n="apiEdit">Modifier</button>
            <button id="btnClearKey2" class="btn-text-action btn-text-danger" data-i18n="apiDisconnect">Déconnecter</button>
          </div>
        </div>
        <div class="api-inner" id="apiForm">
          <div class="api-label">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
            <span data-i18n="apiLabel">Clé API AudD</span> <span class="api-badge" data-i18n="apiIdent">Identification</span>
          </div>
          <div class="api-field-wrap">
            <input type="password" id="apiKeyInput" data-i18n-placeholder="apiPlaceholder" placeholder="Colle ta clé AudD ici…" autocomplete="off" spellcheck="false"/>
            <button id="btnSaveKey" class="btn-save" data-i18n="apiSave">Sauvegarder</button>
            <button id="btnCancelEdit" class="btn-clear" style="display:none">✕</button>
          </div>
          <p class="api-hint" id="apiHint" data-i18n="apiHint">La clé est stockée uniquement dans ton navigateur.</p>
        </div>
      </section>

      <!-- DROP ZONE -->
      <section class="drop-zone" id="dropZone">
        <div class="drop-inner">
          <div class="drop-icon">
            <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="2"/>
              <path d="M24 14v12M18 20l6-6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M16 34h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </div>
          <p class="drop-title" data-i18n="dropTitle">Dépose ton fichier audio ici</p>
          <p class="drop-sub">MP3, WAV, FLAC, AAC</p>
          <label class="btn-upload" for="fileInput" data-i18n="dropBtn">Choisir un fichier</label>
          <input type="file" id="fileInput" accept="audio/*" hidden />
        </div>
      </section>

      <!-- PROGRESSION -->
      <div class="progress-wrap" id="progressWrap">
        <div class="progress-bar" id="progressBar"></div>
        <span class="progress-label" id="progressLabel"></span>
      </div>

      <!-- RÉSULTATS -->
      <section class="results" id="results">
        <div class="result-card" id="cardBPM">
          <span class="card-label">BPM</span>
          <span class="card-value" id="bpmValue">—</span>
          <span class="card-sub" id="bpmSub"></span>
        </div>
        <div class="result-card" id="cardKeyEU">
          <span class="card-label" data-i18n="keyEULabel">Clé européenne</span>
          <span class="card-value" id="keyEUValue">—</span>
          <span class="card-sub" id="keyEUSub"></span>
        </div>
        <div class="result-card" id="cardKeyUS">
          <span class="card-label" data-i18n="keyUSLabel">Clé américaine (Camelot)</span>
          <span class="card-value" id="keyUSValue">—</span>
          <span class="card-sub" id="keyUSSub" data-i18n="camelotWheel">Roue de Camelot</span>
        </div>
      </section>

      <!-- WAVEFORM -->
      <section class="waveform-section" id="waveformSection">
        <canvas id="waveformCanvas"></canvas>
        <div class="player-controls">
          <button class="btn-play" id="btnPlay">
            <svg id="iconPlay" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            <svg id="iconPause" viewBox="0 0 24 24" fill="currentColor" style="display:none"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
          </button>
          <div class="time-display">
            <span id="timeCurrent">0:00</span>
            <span class="time-sep">/</span>
            <span id="timeDuration">0:00</span>
          </div>
        </div>
      </section>

      <!-- IDENTIFICATION -->
      <section class="identify-section" id="identifySection">
        <div class="identify-loading" id="identifyLoading">
          <div class="spinner"></div>
          <span data-i18n="identLoading">Identification via AudD…</span>
        </div>
        <div class="identify-result" id="identifyResult">
          <div class="identify-cover-wrap"><img id="identifyCover" src="" alt="Cover"/></div>
          <div class="identify-info">
            <p class="identify-track" id="identifyTrack">—</p>
            <p class="identify-artist" id="identifyArtist">—</p>
            <p class="identify-album" id="identifyAlbum">—</p>
            <div class="identify-tags" id="identifyTags"></div>
            <div class="identify-links" id="identifyLinks"></div>
          </div>
        </div>
        <div class="identify-notfound" id="identifyNotFound">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35M11 8v6M11 14h.01"/></svg>
          <span data-i18n="identNotFound">Morceau non identifié par AudD</span>
        </div>
        <div class="identify-nokey" id="identifyNoKey">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
          <span data-i18n="identNoKey">Ajoute une clé AudD pour activer l'identification</span>
        </div>
      </section>

    </main>

    <footer class="footer">
      <p data-i18n="footer">BeatKey — Analyse locale · Identification via AudD · Aucune donnée stockée</p>
    </footer>

  </div><!-- /app-wrap -->

