  dropZone.addEventListener('dragleave',()=>dropZone.classList.remove('drag-over'));
  dropZone.addEventListener('drop',e=>{e.preventDefault();dropZone.classList.remove('drag-over');const f=e.dataTransfer.files[0];if(f&&f.type.startsWith('audio/')){stopPlayer();analyzeFile(f);}});
  fileInput.addEventListener('change',e=>{if(e.target.files[0]){stopPlayer();analyzeFile(e.target.files[0]);}e.target.value='';});

  applyTranslations();
  </script>
</body>
</html>
