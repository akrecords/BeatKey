  // ── Analyse ─────────────────────────────────────────────
  async function analyzeFile(file){
    progressWrap.classList.add('visible');results.classList.remove('visible');
    waveformSection.classList.remove('visible');identifySection.style.display='none';
    setProgress(10,t('progReading'));
    const ab=await file.arrayBuffer();
    setProgress(30,t('progDecoding'));
    if(!audioCtx)audioCtx=new(window.AudioContext||window.webkitAudioContext)();
    audioBuffer=await audioCtx.decodeAudioData(ab.slice(0));
    setProgress(50,t('progBPM'));await sleep(20);
    lastBPM=detectBPM(audioBuffer,audioBuffer.sampleRate);
    setProgress(72,t('progKey'));await sleep(20);
    const chroma=getChromagram(audioBuffer,audioBuffer.sampleRate);
    lastKeyUS=detectKey(chroma);
    setProgress(90,t('progFinal'));await sleep(100);
    document.getElementById('bpmValue').textContent=lastBPM;
    renderBpmSub(lastBPM);renderKeyResult(lastKeyUS);
    setProgress(100,t('progDone'));await sleep(200);
    progressWrap.classList.remove('visible');results.classList.add('visible');
    drawWaveform(audioBuffer);waveformSection.classList.add('visible');
    timeDuration.textContent=formatTime(audioBuffer.duration);
    const apiKey=getApiKey();
    if(!apiKey){showIdentifyState('nokey');}
    else{
      showIdentifyState('loading');
      try{const data=await identifyWithAudd(file,apiKey);if(data.status==='success'&&data.result)renderIdentifyResult(data);else showIdentifyState('notfound');}
      catch(err){console.error('AudD:',err);showIdentifyState('notfound');}
    }
  }

  function drawWaveform(buffer){
    const data=buffer.getChannelData(0),W=canvas.parentElement.offsetWidth||800,H=80;
    canvas.width=W;canvas.height=H;
    const ctx=canvas.getContext('2d'),step=Math.ceil(data.length/W);
    const g=ctx.createLinearGradient(0,0,W,0);
    g.addColorStop(0,'#00e5a0');g.addColorStop(0.5,'#00b8ff');g.addColorStop(1,'#00e5a0');
    ctx.strokeStyle=g;ctx.lineWidth=1.5;ctx.beginPath();
    for(let i=0;i<W;i++){let mn=1,mx=-1;for(let j=0;j<step;j++){const v=data[i*step+j]||0;if(v<mn)mn=v;if(v>mx)mx=v;}ctx.moveTo(i,(1+mn)/2*H);ctx.lineTo(i,(1+mx)/2*H);}
    ctx.stroke();
  }

