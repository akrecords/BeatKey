  let currentLang = localStorage.getItem('beatkey_lang') || 'fr';
  function t(k){ return TRANSLATIONS[currentLang][k] || TRANSLATIONS.fr[k] || k; }

  function applyTranslations(){
    document.documentElement.lang = currentLang;
    document.querySelectorAll('[data-i18n]').forEach(el => el.textContent = t(el.dataset.i18n));
    document.querySelectorAll('[data-i18n-placeholder]').forEach(el => el.placeholder = t(el.dataset.i18nPlaceholder));
    document.querySelectorAll('.lang-btn').forEach(btn => btn.classList.toggle('active', btn.dataset.lang === currentLang));
    if(lastBPM !== null) renderBpmSub(lastBPM);
    if(lastKeyUS !== null) renderKeyResult(lastKeyUS);
  }

  document.getElementById('langSwitcher').addEventListener('click', e => {
    const btn = e.target.closest('.lang-btn');
    if(!btn) return;
    currentLang = btn.dataset.lang;
    localStorage.setItem('beatkey_lang', currentLang);
    applyTranslations();
  });

  // ═══════════════════════════════════════════════════════════
  //  AUTH — localStorage simulation
  // ═══════════════════════════════════════════════════════════
  const authOverlay = document.getElementById('authOverlay');
  const appWrap     = document.getElementById('appWrap');

  function getUsers(){ try{ return JSON.parse(localStorage.getItem('beatkey_users')||'{}'); }catch(e){ return {}; } }
  function saveUsers(u){ localStorage.setItem('beatkey_users', JSON.stringify(u)); }
  function getCurrentUser(){ try{ return JSON.parse(localStorage.getItem('beatkey_current')||'null'); }catch(e){ return null; } }
  function setCurrentUser(u){ localStorage.setItem('beatkey_current', JSON.stringify(u)); }
  function clearCurrentUser(){ localStorage.removeItem('beatkey_current'); }

  function hashSimple(str){
    // Hash léger côté client — remplacer par bcrypt côté serveur avec Firebase
    let h = 0;
    for(let i=0; i<str.length; i++) h = (Math.imul(31, h) + str.charCodeAt(i)) | 0;
    return h.toString(36);
  }

  function showApp(user){
    authOverlay.style.display = 'none';
    appWrap.style.display = 'flex';
    // Mettre à jour le profil
    const initials = user.name ? user.name.split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2) : user.email[0].toUpperCase();
    document.getElementById('userAvatar').textContent = initials;
    document.getElementById('userDropdownName').textContent = user.name || 'Utilisateur';
    document.getElementById('userDropdownEmail').textContent = user.email;
    applyTranslations();
  }

  function showAuth(){
    appWrap.style.display = 'none';
    authOverlay.style.display = 'flex';
  }

  // Init : si déjà connecté
  const existing = getCurrentUser();
  if(existing){ showApp(existing); } else { showAuth(); }

