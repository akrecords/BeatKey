  //  MAPPINGS MUSICAUX
  // ═══════════════════════════════════════════════════════════
  const CAMELOT = {
    "C maj":"8B","Db maj":"3B","D maj":"10B","Eb maj":"5B","E maj":"12B","F maj":"7B",
    "F# maj":"2B","G maj":"9B","Ab maj":"4B","A maj":"11B","Bb maj":"6B","B maj":"1B",
    "A min":"8A","Bb min":"3A","B min":"10A","C min":"5A","C# min":"12A","D min":"7A",
    "Eb min":"2A","E min":"9A","F min":"4A","F# min":"11A","G min":"6A","G# min":"1A"
  };
  const NOTE_DISPLAY_MAJ = ["C","Db","D","Eb","E","F","F#","G","Ab","A","Bb","B"];
  const NOTE_DISPLAY_MIN  = ["C","C#","D","Eb","E","F","F#","G","Ab","A","Bb","B"];
  const MAJ_PROFILE = [6.35,2.23,3.48,2.33,4.38,4.09,2.52,5.19,2.39,3.66,2.29,2.88];
  const MIN_PROFILE = [6.33,2.68,3.52,5.38,2.60,3.53,2.54,4.75,3.98,2.69,3.34,3.17];

  function localizeKey(keyUS){
    const parts=keyUS.split(' '), note=parts[0], mode=parts[1];
    const lc=TRANSLATIONS[currentLang];
    return `${lc.noteNames[note]||note} ${lc[mode]||mode}`;
  }

  // ═══════════════════════════════════════════════════════════
  //  ALGOS
  // ═══════════════════════════════════════════════════════════
  function pearson(a,b){
    const n=a.length,ma=a.reduce((s,v)=>s+v,0)/n,mb=b.reduce((s,v)=>s+v,0)/n;
    let num=0,da=0,db=0;
    for(let i=0;i<n;i++){const x=a[i]-ma,y=b[i]-mb;num+=x*y;da+=x*x;db+=y*y;}
    return num/Math.sqrt(da*db||1);
  }
  function fft(re,im){
    const n=re.length;
    for(let i=1,j=0;i<n;i++){let bit=n>>1;for(;j&bit;bit>>=1)j^=bit;j^=bit;if(i<j){[re[i],re[j]]=[re[j],re[i]];[im[i],im[j]]=[im[j],im[i]];}}
    for(let len=2;len<=n;len<<=1){const ang=-2*Math.PI/len,wRe=Math.cos(ang),wIm=Math.sin(ang);for(let i=0;i<n;i+=len){let cR=1,cI=0;for(let j=0;j<len/2;j++){const uR=re[i+j],uI=im[i+j],vR=re[i+j+len/2]*cR-im[i+j+len/2]*cI,vI=re[i+j+len/2]*cI+im[i+j+len/2]*cR;re[i+j]=uR+vR;im[i+j]=uI+vI;re[i+j+len/2]=uR-vR;im[i+j+len/2]=uI-vI;const nR=cR*wRe-cI*wIm;cI=cR*wIm+cI*wRe;cR=nR;}}}
  }
  function getChromagram(buffer,sampleRate){
    let mono;
    if(buffer.numberOfChannels>=2){const L=buffer.getChannelData(0),R=buffer.getChannelData(1);mono=new Float32Array(L.length);for(let i=0;i<L.length;i++)mono[i]=(L[i]+R[i])*0.5;}
    else mono=buffer.getChannelData(0);
    const N=8192,HOP=2048,chroma=new Float64Array(12),hann=new Float32Array(N);
    for(let i=0;i<N;i++)hann[i]=0.5*(1-Math.cos(2*Math.PI*i/(N-1)));
    for(let start=0;start+N<=mono.length;start+=HOP){
      const re=new Float64Array(N),im=new Float64Array(N);
      for(let i=0;i<N;i++)re[i]=mono[start+i]*hann[i];
      fft(re,im);
      for(let k=1;k<N/2;k++){const freq=k*sampleRate/N;if(freq<27.5||freq>4200)continue;const midi=12*Math.log2(freq/440)+69,nc=((Math.round(midi)%12)+12)%12;chroma[nc]+=Math.sqrt(re[k]*re[k]+im[k]*im[k]);}
    }
    let norm=0;for(let i=0;i<12;i++)norm+=chroma[i]*chroma[i];norm=Math.sqrt(norm)||1;
    return chroma.map(v=>v/norm);
  }
  function detectKey(chroma){
    let best={score:-Infinity,note:0,mode:'maj'};
    for(let i=0;i<12;i++){
      const sh=[...chroma.slice(i),...chroma.slice(0,i)];
      const mj=pearson(sh,MAJ_PROFILE),mn=pearson(sh,MIN_PROFILE);
      if(mj>best.score)best={score:mj,note:i,mode:'maj'};
      if(mn>best.score)best={score:mn,note:i,mode:'min'};
    }
    return `${best.mode==='maj'?NOTE_DISPLAY_MAJ[best.note]:NOTE_DISPLAY_MIN[best.note]} ${best.mode}`;
  }
  function detectBPM(buffer,sampleRate){
    const T=8000,d=Math.max(1,Math.floor(sampleRate/T));
    const raw=buffer.getChannelData(0),ds=new Float32Array(Math.floor(raw.length/d));
    for(let i=0;i<ds.length;i++)ds[i]=raw[i*d];
    const sr=sampleRate/d,W=Math.round(sr*0.025),H=Math.round(sr*0.010);
    const energy=[];
    for(let i=0;i+W<ds.length;i+=H){let e=0;for(let j=i;j<i+W;j++)e+=ds[j]*ds[j];energy.push(e/W);}
    const onset=new Float64Array(energy.length);
    for(let i=1;i<energy.length;i++)onset[i]=Math.max(0,energy[i]-energy[i-1]);
    const maxO=Math.max(...onset)||1;for(let i=0;i<onset.length;i++)onset[i]/=maxO;
    const ht=H/sr,minL=Math.round(60/(200*ht)),maxL=Math.round(60/(60*ht));
    const ac=new Float64Array(maxL+1);
    for(let lag=minL;lag<=maxL;lag++){let s=0;for(let i=0;i+lag<onset.length;i++)s+=onset[i]*onset[i+lag];ac[lag]=s;}
    let bL=minL,bV=-Infinity;
    for(let lag=minL;lag<=maxL;lag++){if(ac[lag]>bV){bV=ac[lag];bL=lag;}}
    let bpm=60/(bL*ht);
    while(bpm<80&&bpm*2<=185)bpm*=2;while(bpm>185&&bpm/2>=80)bpm/=2;
    return Math.round(bpm);
  }

  // ═══════════════════════════════════════════════════════════
  //  AUDD
  // ═══════════════════════════════════════════════════════════
  async function identifyWithAudd(file,apiKey){
    const ab=await file.arrayBuffer();
    const tmp=new(window.AudioContext||window.webkitAudioContext)();
    const dec=await tmp.decodeAudioData(ab);tmp.close();
    const sr=dec.sampleRate,tot=dec.length,nCh=dec.numberOfChannels;
    const ss=Math.min(30*sr,Math.floor(tot*0.2)),es=Math.min(ss+20*sr,tot);
    const off=new OfflineAudioContext(nCh,es-ss,sr);
    const src=off.createBufferSource();
    const seg=new AudioBuffer({numberOfChannels:nCh,length:es-ss,sampleRate:sr});
    for(let c=0;c<nCh;c++)seg.copyToChannel(dec.getChannelData(c).slice(ss,es),c);
    src.buffer=seg;src.connect(off.destination);src.start();
    const ren=await off.startRendering();
    const wav=audioBufferToWavBlob(ren);
    const fd=new FormData();
    fd.append('api_token',apiKey);fd.append('file',wav,'sample.wav');fd.append('return','spotify,apple_music,deezer');
    const r=await fetch('https://api.audd.io/',{method:'POST',body:fd});
    if(!r.ok)throw new Error('AudD '+r.status);
    return r.json();
  }
  function audioBufferToWavBlob(buf){
    const nCh=buf.numberOfChannels,sr=buf.sampleRate,len=buf.length;
    const ab=new ArrayBuffer(44+len*nCh*2),v=new DataView(ab);
    const ws=(o,s)=>{for(let i=0;i<s.length;i++)v.setUint8(o+i,s.charCodeAt(i));};
    ws(0,'RIFF');v.setUint32(4,36+len*nCh*2,true);ws(8,'WAVE');ws(12,'fmt ');
    v.setUint32(16,16,true);v.setUint16(20,1,true);v.setUint16(22,nCh,true);
    v.setUint32(24,sr,true);v.setUint32(28,sr*nCh*2,true);v.setUint16(32,nCh*2,true);v.setUint16(34,16,true);
    ws(36,'data');v.setUint32(40,len*nCh*2,true);
    let off=44;
    for(let i=0;i<len;i++)for(let c=0;c<nCh;c++){const s=Math.max(-1,Math.min(1,buf.getChannelData(c)[i]));v.setInt16(off,s<0?s*0x8000:s*0x7FFF,true);off+=2;}
    return new Blob([ab],{type:'audio/wav'});
  }

